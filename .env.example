# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=skillbridge
POSTGRES_PASSWORD=skillbridge
POSTGRES_DB=skillbridge

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://skillbridge:skillbridge@postgres:5432/skillbridge
REDIS_URL=redis://redis:6379
JWT_SECRET=supersecretjwtkey2024skillbridge

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: "mock" | "openai" | "gemini"
AI_PROVIDER=mock
MOCK_AI_MODE=true

# OpenAI (production recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (development/testing)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# AI behaviour controls
AI_CACHE_TTL_SECONDS=86400
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=1200
AI_REQUEST_TIMEOUT_SECONDS=30
